{
  "name": "YouTube Transcript Reader",
  "description": "Read YouTube transcripts without clicking Show transcript. Search, copy, and click timestamps to jump.",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": [
    "scripting",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
